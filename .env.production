# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-generate-with-python-secrets-module

# Database Configuration (PostgreSQL - NOTE: App uses MySQL/pymysql!)
# This is a PostgreSQL database but the app uses MySQL driver (pymysql)
# You need to either:
# 1. Use a MySQL database instead (PlanetScale, Render MySQL, etc.)
# 2. Or migrate the app to use PostgreSQL (psycopg2)
DB_HOST=your-db-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_PORT=3306
DB_SSL=true

# Encryption Key
ENCRYPTION_KEY=your-encryption-key-here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=KAIZY

# LLM Provider Configuration
PRIMARY_PROVIDER=groq

# Groq
GROQ_API_KEYS=your-groq-api-key-1,your-groq-api-key-2
GROQ_MODELS=llama-3.1-8b-instant,mixtral-8x7b-32768

# Mistral AI
MISTRAL_API_KEYS=your-mistral-api-key-1,your-mistral-api-key-2
MISTRAL_MODELS=mistral-small-latest,mistral-medium-latest

# OpenRouter
OPENROUTER_API_KEYS=your-openrouter-api-key-1,your-openrouter-api-key-2
OPENROUTER_MODELS=mistralai/mistral-7b-instruct:free,mistralai/mistral-7b-instruct,google/gemma-2-9b-it:free

# Custom
CUSTOM_API_KEYS=your-custom-api-key
CUSTOM_MODELS=gpt-3.5-turbo
CUSTOM_BASE_URL=https://api.openai.com/v1

# Admin Key
ADMIN_KEY=your-admin-secret-key

# Contact Information
CONTACT_EMAIL=sales@kaizenmeds.com
CONTACT_PHONE=+91 966 550 2190
CONTACT_WEBSITE=kaizy.com